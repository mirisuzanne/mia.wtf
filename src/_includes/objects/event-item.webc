<a
  webc:if="this.show.data['bookmark-of']"
  :href="this.show.data['bookmark-of']"
  @text="this.show.data.title"
></a>
<em
  webc:else
  @html="mdI(this.show.data.title)"
></em>
&ndash;
<date-time
  :@date="this.show.data.date"
  @format="recent"
></date-time>
@
<span
  webc:nokeep
  @text="this.show.data.venue"
></span>
<span
  webc:if="this.show.data.adr && onGoing(this.show)"
  @text="`[${show.data.adr}]`"
></span>
