<section
  webc:root="override"
  webc:if="this.pages?.length > 0"
>
  <slot><h2>Articles &c.</h2></slot>

  <ul>
    <li
      webc:is="post-item"
      webc:for="post of this.pages"
      :@post="post"
    ></li>
  </ul>

  <p webc:if="this.more">
    (<a href="/tags/is:post/">
      more posts »
    </a>)
  </p>
</section>
