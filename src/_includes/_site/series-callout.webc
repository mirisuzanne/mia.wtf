<details
  webc:if="this.pages?.length > 0"
>
  <summary>This post is part of a series…</summary>
  <ul>
    <li
      webc:is="post-item"
      webc:for="post of this.pages"
      :@post="post"
    ></li>
  </ul>
</details>

<style>
  series-callout {
    display: block;
    margin-block-end: 1lh;
  }
</style>
