<script webc:setup>
  export const formatText = (prefix, date, format) => {
    const dateText = dateFormat(date, format);
    return prefix ? `${mdInline(prefix)} ${dateText}` : dateText;
  }
</script>

<time
  :datetime="dateFormat(this.date, 'iso')"
  @text="this.as || formatText(this.prefix, this.date, this.format)"
  @attributes
></time>
