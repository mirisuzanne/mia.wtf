---
layout: false
permalink: feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ permalink | htmlBaseUrl(baseURL) }}" rel="self" />
  <link href="{{ baseURL | addPathPrefixToFullUrl }}" />
  <updated>{{ collections.feed | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ baseURL | addPathPrefixToFullUrl }}</id>
  <author>
    <name>{{ site.author }}</name>
  </author>
  {%- for post in collections.feed | batch(15) | first %}
  {%- set absolutePostUrl %}{{ post.url | htmlBaseUrl(baseURL) }}{% endset %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ absolutePostUrl }}" />
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ absolutePostUrl }}</id>
    <content type="html">{{ post.content | renderTransforms(post.data.page, baseURL) }}</content>
  </entry>
  {%- endfor %}
</feed>
